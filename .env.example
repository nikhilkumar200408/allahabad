# Core Banking Simulation Platform - Environment Configuration
# Copy to .env.local and update with your values

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://app.mybank.local
BACKEND_URL=https://api.mybank.local

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://banking_user:banking_password_dev@localhost:5432/core_banking_db

# PostgreSQL connection pool settings
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT_MS=30000

# ============================================================================
# REDIS (Caching, Distributed Locking, Sessions)
# ============================================================================
# Format: redis://[:password]@host:port
REDIS_URL=redis://localhost:6379

# Redis cluster mode (for HA)
REDIS_CLUSTER_ENABLED=false
REDIS_CLUSTER_NODES=redis1:6379,redis2:6379,redis3:6379

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Secret key for JWT signing (use strong, random value in production)
# Generate: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_here_generate_strong_random_key

# JWT token expiry times
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# JWT audience and issuer
JWT_ISSUER=banking-platform
JWT_AUDIENCE=banking-platform-api

# ============================================================================
# BLOCKCHAIN CONFIGURATION
# ============================================================================
# Supported chains: ethereum, polygon, hardhat (local)
BLOCKCHAIN_CHAIN=ethereum

# RPC endpoint URL
# Ethereum Mainnet: https://eth-mainnet.alchemyapi.io/v2/YOUR_API_KEY
# Polygon: https://polygon-rpc.com
# Local (Hardhat): http://localhost:8545
BLOCKCHAIN_RPC_URL=http://localhost:8545

# Private key of account that will submit transactions (0x-prefixed)
# CRITICAL: Keep this secret, never commit to version control
# Use secrets management (HashiCorp Vault, AWS Secrets Manager, etc.)
BLOCKCHAIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb476caded87985b5b3d6ac99c7a1

# Smart contract address (deployed BankingAuditLedger)
BLOCKCHAIN_CONTRACT_ADDRESS=0x5FbDB2315678afccb333f8a9fcff40144d8c758c

# Blockchain address derivation salt (for privacy)
BLOCKCHAIN_ADDRESS_DERIVATION_SALT=banking-audit-ledger-v1-salt

# Gas price and limits
BLOCKCHAIN_GAS_PRICE_GWEI=30
BLOCKCHAIN_GAS_LIMIT_ANCHOR=300000

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================
# Mobile operators (Jio, Airtel, BSNL)
JIO_API_KEY=jio_api_key_here
JIO_API_SECRET=jio_api_secret_here
JIO_API_ENDPOINT=https://api.jio.com/v1

AIRTEL_API_KEY=airtel_api_key_here
AIRTEL_API_SECRET=airtel_api_secret_here
AIRTEL_API_ENDPOINT=https://api.airtel.com/v2

BSNL_API_KEY=bsnl_api_key_here
BSNL_API_ENDPOINT=https://api.bsnl.co.in/v1

# Utility payment gateways
ELECTRICITY_BOARD_API_KEY=board_api_key_here
ELECTRICITY_BOARD_ENDPOINT=https://api.stateelectricity.gov.in

# Payment processor (for settlement, optional)
SETTLEMENT_PROVIDER_API_KEY=settlement_key_here
SETTLEMENT_PROVIDER_ENDPOINT=https://api.settlement.gov.in

# ============================================================================
# SECURITY & ENCRYPTION
# ============================================================================
# Password hashing: bcrypt rounds (10-12 recommended)
BCRYPT_ROUNDS=12

# Encryption key for sensitive data at rest (32 bytes for AES-256)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=your_aes_256_encryption_key_here_32_bytes_hex

# Rate limiting
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/banking-platform

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================
# APM (Application Performance Monitoring)
APM_ENABLED=true
APM_SERVICE_NAME=core-banking-platform
APM_SERVER_URL=https://apm-server:8200

# OpenTelemetry
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector:4317

# Sentry error tracking
SENTRY_ENABLED=true
SENTRY_DSN=https://key@sentry.io/project-id

# ============================================================================
# EMAIL NOTIFICATIONS
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=noreply@mybank.local
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM_EMAIL=noreply@mybank.local
SMTP_FROM_NAME=MyBank Platform

# ============================================================================
# SMS NOTIFICATIONS (for OTP, alerts)
# ============================================================================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Alternative: AWS SNS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ============================================================================
# DATABASE BACKUP & REPLICATION
# ============================================================================
# S3 bucket for backup storage
BACKUP_S3_BUCKET=banking-platform-backups
BACKUP_S3_REGION=ap-south-1
BACKUP_RETENTION_DAYS=30

# Replication endpoint (for standby database)
REPLICA_DATABASE_URL=postgresql://banking_user:password@standby-host:5432/core_banking_db

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_BLOCKCHAIN_ANCHORING_ENABLED=true
FEATURE_KYC_VERIFICATION_ENABLED=true
FEATURE_MOBILE_RECHARGE_ENABLED=true
FEATURE_UTILITY_PAYMENT_ENABLED=true

# ============================================================================
# COMPLIANCE & AUDIT
# ============================================================================
# PCI-DSS compliance
PCI_DSS_MODE=true

# GDPR compliance
GDPR_ENABLED=true
DATA_RETENTION_DAYS=2555 # 7 years per RBI

# AML/CFT (Anti-Money Laundering / Counter Financing of Terrorism)
AML_CHECK_ENABLED=true
AML_THRESHOLD_AMOUNT=100000

# ============================================================================
# ASYNC JOB WORKER
# ============================================================================
WORKER_ENABLED=true
WORKER_POLL_INTERVAL_MS=5000
WORKER_MAX_CONCURRENT_JOBS=10
WORKER_JOB_TIMEOUT_MS=60000

# ============================================================================
# DEVELOPMENT / TESTING ONLY
# ============================================================================
# NEVER enable these in production!
DEBUG_MODE=false
MOCK_BLOCKCHAIN=false
MOCK_PAYMENT_GATEWAYS=false
SEED_DATABASE=false
